   "source": [
    "# Databricks notebook source\n",
    "\n",
    "def write_delta(\n",
    "    df,\n",
    "    path,\n",
    "    mode=\"overwrite\"\n",
    "):\n",
    "\n",
    "    (\n",
    "        df.write\n",
    "        .format(\"delta\")\n",
    "        .mode(mode)\n",
    "        .option(\"overwriteSchema\", \"true\")\n",
    "        .save(path)\n",
    "    )\n",
    "\n",
    "    print(f\"Tabela salva em: {path}\")"
   ]
  }
 ],
